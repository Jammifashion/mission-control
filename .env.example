# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# API-Key zum Schutz aller Backend-Routen (außer /health und /api/health/full)
# Beliebiger sicherer Zufallswert, z.B.: openssl rand -hex 32
MC_API_KEY=

# Erlaubte Frontend-Origins für CORS (kommagetrennt für mehrere)
# Production: nur GitHub Pages; Development: localhost ergänzen
CORS_ORIGIN=https://jammifashion.github.io,http://localhost:5173

# ── WooCommerce ───────────────────────────────────────────────────────────────
# Shop-URL ohne abschließenden Slash
WC_URL=https://your-shop.de

# REST API Zugangsdaten – generieren unter: WooCommerce → Einstellungen → Erweitert → REST API
WC_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Standard-Modell überschreiben (Standard: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini-Modell überschreiben (Standard: gemini-2.5-flash-preview-05-20)
# GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# ── Google Cloud / Sheets ─────────────────────────────────────────────────────
# Google Sheets Spreadsheet-ID (aus der URL: /spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your-spreadsheet-id

# GCP Projekt-ID (für Cloud Run / Secret Manager)
GOOGLE_PROJECT_ID=mission-control-495711

# Google Auth – eine der beiden Optionen wählen:
#
# Option A (Lokale Entwicklung): Pfad zur Service-Account JSON-Datei
#   GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json
#
# Option B (Lokal oder CI): Service-Account JSON direkt als String (eine Zeile)
#   cat key.json | tr -d '\n'  → Inhalt hier einfügen
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# ── Notifications (ntfy.sh) ───────────────────────────────────────────────────
# Optional: Eindeutiger Topic-Name – unter https://ntfy.sh/<NTFY_TOPIC> abonnieren
# NTFY_TOPIC=mc-alerts-xyz

# ── Google Drive Backup ───────────────────────────────────────────────────────
GOOGLE_DRIVE_SHARED_DRIVE_ID=your-shared-drive-id
GOOGLE_DRIVE_BACKUP_DAILY_ID=your-daily-folder-id
GOOGLE_DRIVE_BACKUP_MONTHLY_ID=your-monthly-folder-id
