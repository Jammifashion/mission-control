# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Allowed frontend origin for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# ── WooCommerce ───────────────────────────────────────────────────────────────
# Your WooCommerce store URL (no trailing slash)
WC_URL=https://your-shop.de

# REST API credentials – generate at: WooCommerce → Einstellungen → Erweitert → REST API
WC_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override default model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Google Cloud / Sheets ─────────────────────────────────────────────────────
# Google Sheets Spreadsheet-ID (aus der URL: /spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your-spreadsheet-id

# Lokale Entwicklung: Service-Account JSON direkt als Inhalt (eine Zeile, escaped)
# In der GCP Console: IAM → Service Accounts → Key erstellen → JSON herunterladen
# Inhalt in eine Zeile: cat key.json | tr -d '\n'
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# Produktion (Secret Manager) – wird genutzt wenn GOOGLE_CREDENTIALS_JSON nicht gesetzt ist
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_SECRET_NAME=mission-control-google-credentials
